#include <winver.h>
#include "@CMAKE_SOURCE_DIR@/src/include/common/ClientVersion.h"

#ifdef __PRERELEASE__
#define VER_PRERELEASE	VS_FF_PRERELEASE
#undef VER_RELEASE
#define VER_RELEASE	0
#define VER_PRODUCTVERSION_STR	"@PACKAGE_VERSION@ @SVNDATE@"
#else
#define VER_PRERELEASE	0
#ifndef VER_RELEASE
#define VER_RELEASE	1
#endif
#define VER_PRODUCTVERSION_STR	"@PACKAGE_VERSION@"
#endif

#ifdef __DEBUG__
#define VER_DEBUG	VS_FF_DEBUG
#else
#define VER_DEBUG	0
#endif

// Default per-binary identification strings. These were referenced by
// the StringFileInfo block below but never defined anywhere -- the file
// silently never compiled on cmake < 3.20 (CMP0115 OLD re-routed the
// missing ${CMAKE_SOURCE_DIR}/version.rc to version.rc.in and dropped
// it as an unrecognised extension), so the mismatch went unnoticed.
// Defining defaults here keeps every Windows aMule binary tagged
// consistently; per-target overrides could come later via -D flags.
#ifndef VER_FILEDESCRIPTION_STR
#define VER_FILEDESCRIPTION_STR		"aMule eDonkey/Kademlia client"
#endif
#ifndef VER_INTERNALNAME_STR
#define VER_INTERNALNAME_STR		"aMule"
#endif
#ifndef VER_ORIGINALFILENAME_STR
#define VER_ORIGINALFILENAME_STR	"amule.exe"
#endif

VS_VERSION_INFO VERSIONINFO
	FILEVERSION	VERSION_MJR, VERSION_MIN, VERSION_UPDATE, VER_RELEASE
	PRODUCTVERSION	VERSION_MJR, VERSION_MIN, VERSION_UPDATE, VER_RELEASE
	FILEFLAGSMASK	VS_FFI_FILEFLAGSMASK
	FILEFLAGS	VER_DEBUG | VER_PRERELEASE
	FILEOS		VOS__WINDOWS32
	FILETYPE	VFT_APP
	FILESUBTYPE	0x0L
BEGIN
	BLOCK "StringFileInfo"
	BEGIN
		BLOCK "040904b0"
		BEGIN
			VALUE	"Comments",		"https://github.com/amule-org/amule"
			VALUE	"FileDescription",	VER_FILEDESCRIPTION_STR
			VALUE	"FileVersion",		VER_PRODUCTVERSION_STR
			VALUE	"InternalName",		VER_INTERNALNAME_STR
			VALUE	"OriginalFilename",	VER_ORIGINALFILENAME_STR
			VALUE	"ProductName",		"aMule"
			VALUE	"ProductVersion",	VER_PRODUCTVERSION_STR
			VALUE	"LegalCopyright",	"aMule Team ( admin@amule.org )"
		END
	END
	BLOCK "VarFileInfo"
	BEGIN
		VALUE	"Translation", 0x0409, 1200
	END
END
