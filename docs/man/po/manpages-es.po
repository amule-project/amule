msgstr "B<[ -t> I<E<lt>nameE<gt>>, B<--template>=I<E<lt>nameE<gt>> B<]>"

#. type: Plain text
#: ed2k.1.in:28
msgid ""
"Set category for passed eD2k links to I<E<lt>numE<gt>>.  Unlike B<--config-"
"dir>, the parser reads the value as the next argument and does not accept "
"B<--category>=I<E<lt>numE<gt>> syntax."
msgstr ""

