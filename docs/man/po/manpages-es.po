msgstr "[B<-c> I<E<lt>pathE<gt>>] [B<-t> I<E<lt>numE<gt>>]"

#. type: Plain text
#: ed2k.1.in:13
msgid "I<E<lt>eD2k-linkE<gt>>"
msgstr "I<E<lt>eD2k-LinkE<gt>>"

#. type: Plain text
#: ed2k.1.in:21
msgid ""
"Sends the given I<E<lt>eD2k-linkE<gt>> to aMule, i.e. writes it to the file "
"~/.aMule/ED2KLinks, which will be checked by aMule every second for links."
msgstr ""
"Envía el I<E<lt>enlace eD2kE<gt>> a aMule, para ello, lo escribe en el "
"fichero ~/.aMule/ED2KLinks, que aMule lee una vez por segundo."

#. type: TP
#: ed2k.1.in:24
#, fuzzy, no-wrap
#| msgid "B<[ -t> I<E<lt>nameE<gt>>, B<--template>=I<E<lt>nameE<gt>> B<]>"
