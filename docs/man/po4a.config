[po4a_langs] de es fr hu it pt_BR ro ru tr zh_TW
[po4a_paths] po/manpages.pot $lang:po/manpages-$lang.po
[options] --master-charset UTF-8 --localized-charset UTF-8 --addendum-charset UTF-8
[po4a_alias:man] man opt:"-o untranslated=als,B_untranslated,RB_untranslated,IP,SS_untranslated"
[type: man] amule.1.in $lang:amule.$lang.1.in add_$lang:?po/manpages-$lang.add
[type: man] amulecmd.1.in $lang:amulecmd.$lang.1.in add_$lang:?po/manpages-$lang.add
[type: man] amuled.1.in $lang:amuled.$lang.1.in add_$lang:?po/manpages-$lang.add
[type: man] amulegui.1.in $lang:amulegui.$lang.1.in add_$lang:?po/manpages-$lang.add
[type: man] amuleweb.1.in $lang:amuleweb.$lang.1.in add_$lang:?po/manpages-$lang.add
[type: man] ed2k.1.in $lang:ed2k.$lang.1.in add_$lang:?po/manpages-$lang.add
[type: man] ../../src/utils/aLinkCreator/docs/alc.1.in $lang:../../src/utils/aLinkCreator/docs/alc.$lang.1.in add_$lang:?po/manpages-$lang.add
[type: man] ../../src/utils/aLinkCreator/docs/alcc.1.in $lang:../../src/utils/aLinkCreator/docs/alcc.$lang.1.in add_$lang:?po/manpages-$lang.add
[type: man] ../../src/utils/cas/docs/cas.1.in $lang:../../src/utils/cas/docs/cas.$lang.1.in add_$lang:?po/manpages-$lang.add
[type: man] ../../src/utils/wxCas/docs/wxcas.1.in $lang:../../src/utils/wxCas/docs/wxcas.$lang.1.in add_$lang:?po/manpages-$lang.add
